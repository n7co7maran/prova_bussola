generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model computador {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome           String
  cor            String
  datafabricacao Int
  periferico     periferico[]
}

model periferico {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome         String
  computadorid String     @db.Uuid
  computador   computador @relation(fields: [computadorid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_computador")
}
